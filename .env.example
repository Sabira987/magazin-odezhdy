# Meta for Developers -> WhatsApp -> API Setup бетінен алынады
WHATSAPP_TOKEN=сенің_ұзақ_мерзімді_токенің
WHATSAPP_PHONE_NUMBER_ID=сенің_phone_number_id

# Webhook тіркегенде өзің ойлап тауып қоятын құпия сөз (Meta панелінде де дәл осы жазылады)
WEBHOOK_VERIFY_TOKEN=kiim_bot_2026

# Graph API нұсқасы (өзгертпей-ақ қоюға болады)
GRAPH_API_VERSION=v22.0

# /admin панеліне кіру үшін өзің ойлап тауып қоятын құпия токен
# МАҢЫЗДЫ: тек латын әріптері мен сандарды қолданыңыз (кириллица HTTP header-де жұмыс істемейді!)
ADMIN_TOKEN=kiim2026admin

# Render-де беретін сыртқы адрес, мысалы: https://kiim-dukeni-bot.onrender.com
# (Деплой болғаннан кейін осы жерге қойып, қайта сақтаңыз)
PUBLIC_URL=

PORT=3000
